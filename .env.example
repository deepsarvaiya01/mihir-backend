# Local development only — on Render, set these in the dashboard (Environment).
PORT=3000
NODE_ENV=development

# Comma-separated allowed frontend origins (CORS)
FRONTEND_URL=http://localhost:5173

# Aiven PostgreSQL (or local Postgres)
DB_HOST=your-service.aivencloud.com
DB_PORT=12345
DB_USER=avnadmin
DB_PASSWORD=your_password
DB_NAME=laboratory_mihir
DB_SSL=true

# Set to false once schema is stable (recommended for production)
DB_SYNCHRONIZE=true

JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d


MAIL_HOST
smtp.gmail.com
Your SMTP server
MAIL_PORT
587
587 = TLS (recommended), 465 = SSL
MAIL_SECURE
false
Set true only if using port 465
MAIL_USER
you@gmail.com
Login username for SMTP
MAIL_PASS
abcd efgh ijkl mnop
Password or App Password
MAIL_FROM
"Lab Name" <you@gmail.com>
